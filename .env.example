# ─────────────────────────────────────────────
# AK HOME IMPROVEMENT — ENVIRONMENT VARIABLES
#
# LOCAL DEVELOPMENT:
#   Copy this file:  cp .env.example .env.local
#   Fill in your real values in .env.local
#   .env.local is gitignored — it will never be committed.
#
# VERCEL DEPLOYMENT:
#   Go to: Vercel Dashboard → Your Project → Settings → Environment Variables
#   Add each VITE_* variable below with your real values.
# ─────────────────────────────────────────────

# Business Info
VITE_BUSINESS_NAME=Your Business Name LLC
VITE_BUSINESS_TAGLINE=Your City's Trusted Home Improvement Pros
VITE_BUSINESS_LOCATION=Your City, TX

# Contact Details
VITE_CONTACT_PHONE=+1 000-000-0000
VITE_CONTACT_PHONE_HREF=tel:+10000000000
VITE_CONTACT_EMAIL=youremail@gmail.com
VITE_CONTACT_EMAIL_HREF=mailto:youremail@gmail.com
VITE_CONTACT_ADDRESS=123 Main Street, Your City, TX 00000
VITE_CONTACT_ADDRESS_SHORT=123 Main Street, Your City, TX
VITE_CONTACT_MAPS_HREF=https://maps.google.com/?q=123+Main+Street+Your+City+TX
VITE_CONTACT_HOURS=Mon–Sat: 7 AM – 8 PM
VITE_CONTACT_HOURS_SUB=Mon–Sat, 7 AM – 8 PM

# Social Media
VITE_FACEBOOK_URL=https://www.facebook.com/yourpage
VITE_FACEBOOK_LABEL=Your Business Name

# Reviews
VITE_REVIEW_RATING=5.0
VITE_REVIEW_COUNT=0
